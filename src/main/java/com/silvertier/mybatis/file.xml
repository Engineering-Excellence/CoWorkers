<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.silvertier.dto.FileDTO">

    <!-- 전체 글의 개수를 불러온다. -->
    <select id="fileSelectCount" resultType="int">
        SELECT COUNT(*)
        FROM "FILE"
    </select>

    <!-- 1 페이지 분량의 글 목록을 불러온다. -->
    <select id="fileSelectList" parameterType="java.util.HashMap" resultType="fileDTO">
        <![CDATA[
        SELECT *
        FROM (SELECT ROWNUM RNUM, AA.*
              FROM (SELECT *
                    FROM "FILE"
                    ORDER BY FILEID DESC) AA
              WHERE ROWNUM <= #{endNo})
        WHERE RNUM >= #{startNo}
        ]]>
    </select>

    <!-- 모든 공지글을 얻어온다. -->
    <select id="fileSelectNotice" resultType="fileDTO">
        SELECT *
        FROM "FILE"
        WHERE notice = 'true'
        ORDER BY FILEID DESC
    </select>
    
</mapper>